#!/var/jb/bin/sh
set -e
PREFIX=/var/jb
APP="$PREFIX/usr/libexec/openclaw"
PLIST="$PREFIX/Library/LaunchDaemons/ai.openclaw.gateway.plist"
NODE="$APP/node"
STATE="$PREFIX/var/lib/openclaw"

case "$1" in
  configure|"")
    mkdir -p "$STATE" "$PREFIX/var/log" 2>/dev/null || true

    # Pre-create a minimal config so the gateway boots (gateway.mode=local) instead of
    # exiting 78 and crash-looping under launchd before the user runs `openclaw onboard`.
    CFG="$STATE/openclaw.json"
    if [ ! -f "$CFG" ]; then
      printf '{\n  "gateway": { "mode": "local" }\n}\n' > "$CFG" 2>/dev/null || true
    fi

    # Root git needs safe.directory to avoid "dubious ownership" aborts (e.g. self-update).
    GITCFG="$STATE/.gitconfig"
    if [ ! -f "$GITCFG" ]; then
      printf '[safe]\n\tdirectory = *\n' > "$GITCFG" 2>/dev/null || true
    fi

    # The daemon AND the `openclaw` CLI both run as `mobile`, so hand the whole state
    # tree to mobile (uid 501). This is what fixes the `onboard` EACCES on the state dir.
    chown -R mobile "$STATE" 2>/dev/null || chown -R 501 "$STATE" 2>/dev/null || true
    chmod 0700 "$STATE" 2>/dev/null || true
    chmod 0600 "$CFG" 2>/dev/null || true

    # Log file writable by the mobile daemon.
    LOG="$PREFIX/var/log/openclaw.log"
    [ -f "$LOG" ] || : > "$LOG" 2>/dev/null || true
    chown mobile "$LOG" 2>/dev/null || chown 501 "$LOG" 2>/dev/null || true

    chmod 0755 "$NODE" "$APP/run-gateway.sh" "$PREFIX/usr/bin/openclaw" 2>/dev/null || true
    chown root:wheel "$PLIST" 2>/dev/null || true
    chmod 0644 "$PLIST" 2>/dev/null || true

    # Defensive (re)sign node with JIT entitlements using the on-device ldid.
    # The binary is already ldid-signed in CI; this is belt-and-suspenders, non-fatal.
    if [ -x "$PREFIX/usr/bin/ldid" ] && [ -f "$APP/entitlements.plist" ]; then
      "$PREFIX/usr/bin/ldid" -S"$APP/entitlements.plist" "$NODE" 2>/dev/null || true
    fi

    # Load + (re)start the daemon (modern domain syntax, legacy fallback).
    launchctl bootstrap system "$PLIST" 2>/dev/null \
      || launchctl load -w "$PLIST" 2>/dev/null || true
    launchctl kickstart -k system/ai.openclaw.gateway 2>/dev/null || true

    echo "OpenClaw gateway installed. Configure over SSH with: openclaw onboard"
    echo "Logs: $PREFIX/var/log/openclaw.log"
    ;;
esac
exit 0
